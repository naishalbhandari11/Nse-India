<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- Remove default IIS handlers so Python handles all requests -->
    <handlers>
      <remove name="Python FastCGI" />
      <add name="PythonHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified"
           requireAccess="Script" />
    </handlers>

    <!-- HttpPlatformHandler: launches uvicorn as a child process -->
    <httpPlatform processPath="C:\Users\bhand\AppData\Local\Programs\Python\Python312\python.exe"
                  arguments="-m uvicorn app.api:app --host 127.0.0.1 --port %HTTP_PLATFORM_PORT% --workers 4"
                  stdoutLogEnabled="true"
                  stdoutLogFile="C:\Users\bhand\Music\nse-stock-analysis-main\logs\uvicorn.log"
                  startupTimeLimit="120"
                  startupRetryCount="3"
                  requestTimeout="00:10:00">

      <environmentVariables>
        <!-- IIS passes the dynamic port via this variable -->
        <environmentVariable name="HTTP_PLATFORM_PORT" value="%HTTP_PLATFORM_PORT%" />

        <!-- Database -->
        <environmentVariable name="DB_HOST"     value="localhost" />
        <environmentVariable name="DB_PORT"     value="5432" />
        <environmentVariable name="DB_NAME"     value="NseStock" />
        <environmentVariable name="DB_USER"     value="postgres" />
        <environmentVariable name="DB_PASSWORD" value="root" />

        <!-- Auth -->
        <environmentVariable name="SECRET_KEY"  value="change-this-to-a-strong-secret-in-production" />

        <!-- Python path so imports resolve correctly -->
        <environmentVariable name="PYTHONPATH"  value="C:\Users\bhand\Music\nse-stock-analysis-main" />
      </environmentVariables>

    </httpPlatform>

    <!-- Serve static files directly via IIS (faster than going through Python) -->
    <staticContent>
      <mimeMap fileExtension=".js"   mimeType="application/javascript" />
      <mimeMap fileExtension=".css"  mimeType="text/css" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <mimeMap fileExtension=".svg"  mimeType="image/svg+xml" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>

    <!-- Security headers -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options"        value="SAMEORIGIN" />
        <add name="X-XSS-Protection"       value="1; mode=block" />
      </customHeaders>
    </httpProtocol>

  </system.webServer>
</configuration>
